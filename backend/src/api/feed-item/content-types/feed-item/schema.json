{
  "kind": "collectionType",
  "collectionName": "feed_items",
  "info": {
    "singularName": "feed-item",
    "pluralName": "feed-items",
    "displayName": "FeedItem",
    "description": "Feed content for the mobile app"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": ["daily_horoscope", "tip", "news", "announcement"],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": false
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "media": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "language_code": {
      "type": "string",
      "default": "en"
    },
    "priority": {
      "type": "integer",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
