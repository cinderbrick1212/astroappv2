{
    "name": "AstroWitt Build Environment",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17",
            "installGradle": "true"
        }
    },
    "postCreateCommand": "cd mobile && npm ci",
    "customizations": {
        "codespaces": {
            "machine": "standardLinux"
        }
    }
}